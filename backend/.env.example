# Application Settings
APP_NAME=Eventsarthi
ENVIRONMENT=development
DEBUG=true
API_VERSION=v1

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/eventsarthi
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL=3600

# Security
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

# CORS Origins (comma-separated string)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# WhatsApp Cloud API
WHATSAPP_API_TOKEN=your_whatsapp_api_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token
WHATSAPP_API_VERSION=v18.0
WHATSAPP_API_BASE_URL=https://graph.facebook.com

# AI Service Configuration
AI_PROVIDER=openai
# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=500
OPENAI_TEMPERATURE=0.7
# Gemini (alternative)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# AI Confidence Threshold
AI_CONFIDENCE_THRESHOLD=0.7

# Vector Database
VECTOR_DB_PROVIDER=pgvector
# Pinecone (if using)
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_ENVIRONMENT=your_pinecone_environment
PINECONE_INDEX_NAME=eventsarthi

# Storage Configuration
STORAGE_PROVIDER=cloudflare_r2
# Cloudflare R2
CLOUDFLARE_R2_ACCESS_KEY=your_access_key
CLOUDFLARE_R2_SECRET_KEY=your_secret_key
CLOUDFLARE_R2_BUCKET=eventsarthi-storage
CLOUDFLARE_R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
# Supabase Storage (alternative)
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_key
SUPABASE_BUCKET=eventsarthi

# Firebase (for mobile notifications)
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Message Queue
QUEUE_PROVIDER=redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Data Retention
EVENT_DATA_RETENTION_DAYS=30
CONVERSATION_RETENTION_DAYS=30

# Broadcast Settings
BROADCAST_BATCH_SIZE=50
BROADCAST_DELAY_SECONDS=1

# Monitoring
SENTRY_DSN=your_sentry_dsn
LOG_LEVEL=INFO

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# File Upload
MAX_UPLOAD_SIZE_MB=10
ALLOWED_FILE_EXTENSIONS=.pdf,.jpg,.jpeg,.png,.docx